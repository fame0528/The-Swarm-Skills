      "label": "proactive-working-buffer",
      "description": "Checks session context % and auto-compacts buffer at tiered thresholds",
      "schedule": {
        "kind": "every",
        "everyMs": 1800000
      },
      "payload": {
        "kind": "agentTurn",
        "message": "powershell -File C:\\Users\\spenc\\.openclaw\\workspace\\skills\\spencer-proactive-agent\\scripts\\working-buffer.ps1 -Mode monitor -AutoCompact -Quiet -SilentThreshold 60 -NotifyThreshold 90"
      },
      "sessionTarget": "isolated",
      "delivery": {
        "mode": "none"
      },
      "enabled": true
    },
